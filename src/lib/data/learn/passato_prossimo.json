		{ "italian": "Voi avete scritto un'email.", "english": "You all wrote an email." },
		{ "italian": "Loro hanno parlato con Marco.", "english": "They spoke with Marco." },
		{ "italian": "Io sono uscito presto.", "english": "I went out early." },
		{ "italian": "Tu sei venuto qui.", "english": "You came here." },
		{ "italian": "Lei è partita ieri.", "english": "She left yesterday." },
		{ "italian": "Noi abbiamo finito il lavoro.", "english": "We finished the work." }
